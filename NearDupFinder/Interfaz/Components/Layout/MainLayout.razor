@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using NearDupFinder_Dominio.Clases
@inject AuthenticationStateProvider AuthStateProvider
@inject Sistema Sistema

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row px-4" style="display:flex; gap:12px; align-items:center;">
            <span style="flex:1"></span>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-body-secondary">Hola, @context.User.Identity?.Name</span>
                        <form method="post" action="/auth/logout" class="d-inline m-0">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Salir</button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn btn-primary btn-sm">Entrar</a>
                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

       Sistema.InicializarUsuarioDesdeClaims(user);
    }
}