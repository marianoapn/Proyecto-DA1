@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NearDupFinder</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler"/>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="usuarios">
                        <i class="bi bi-people-fill fs-5 lh-1" aria-hidden="true"></i>
                        <span>Usuarios</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="cambiar-clave-usuario">
                        <i class="bi bi-key-fill fs-5 lh-1" aria-hidden="true"></i>
                        <span>Cambiar Contraseña</span>
                    </NavLink>
                </div>     
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="CrearCatalogo">
                        <i class="bi bi-book-fill fs-5 lh-1" aria-hidden="true"></i>
                        <span>Catalogos</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="lista-items">
                        <i class="bi bi-bookmark-dash-fill fs-5 lh-1" aria-hidden="true"></i>
                        <span>Items</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="importar-csv">
                        <i class="bi bi-bookmark-plus-fill fs-5 lh-1" aria-hidden="true"></i>
                        <span>Importar</span>
                    </NavLink>
                </div>     
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="duplicados">
                        <i class="bi bi-copy fs-5 lh-1" aria-hidden="true"></i>
                        <span>Duplicados</span>
                    </NavLink>
                </div>     
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="logs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-clock-history" viewBox="0 0 16 16">
                            <path d="M8.515 3.44a.5.5 0 0 1 .97 0l.07.249a.5.5 0 0 1-.97.07l-.07-.249z"/>
                            <path d="M8 3a5 5 0 1 0 5 5 .5.5 0 0 0-1 0 4 4 0 1 1-4-4 .5.5 0 0 0 0-1z"/>
                            <path d="M8 8V4.5a.5.5 0 0 1 1 0V8h-3a.5.5 0 0 1 0-1h2z"/>
                        </svg>
                        <span>Auditoría</span>
                    </NavLink>
                </div>     
            </Authorized>
        </AuthorizeView>

        
        <AuthorizeView Roles="Revisor, Administrador">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center gap-1" href="Cluster">
                        <i class="bi bi-copy fs-5 lh-1" aria-hidden="true"></i>
                        <span>Cluster</span>
                    </NavLink>
                </div>     
            </Authorized>
        </AuthorizeView>
        
        
    </nav>
</div>