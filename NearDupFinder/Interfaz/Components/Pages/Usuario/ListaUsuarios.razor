@page "/usuarios"
@rendermode InteractiveServer
@using NearDupFinder_Dominio
@using NearDupFinder_Dominio.Clases
@attribute [Authorize(Roles = "Administrador")]
@inject Sistema Sistema

<PageTitle>Usuarios</PageTitle>

<div class="d-flex align-items-center mb-3">
    <h1 class="h1 mb-0">Usuarios</h1>
    <a href="/crear-usuario" class="btn btn-success btn-sm ms-auto">Crear usuario</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
        <tr>
            <th scope="col">Nombre</th>
            <th scope="col">Apellido</th>
            <th scope="col">Email</th>
            <th scope="col">Fecha de nacimiento</th>
            <th scope="col">Roles</th>
            <th scope="col" class="text-end">Acciones</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var usuario in _usuarios!)
        {
            var roles = usuario.ObtenerRoles();
            <tr>
                <td>@usuario.Nombre</td>
                <td>@usuario.Apellido</td>
                <td>@usuario.Email.ToString()</td>
                <td>@usuario.FechaNacimiento.ToString()</td>
                <td>
                    @if (roles.Any())
                    {
                        @string.Join(", ", roles.Select(r => r.ToString()))
                    }
                    else
                    {
                        <em class="text-muted">Sin roles</em>
                    }
                </td>
                <td class="text-end text-nowrap">
                    <div class="d-inline-flex gap-2">
                        <a class="btn btn-primary btn-sm" href="usuarios/@usuario.Id/editar">Editar</a>
                        <button class="btn btn-danger btn-sm" @onclick="(() => EliminarUsuario(usuario.Email))">Eliminar</button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@code {
    private List<Usuario>? _usuarios;

    protected override void OnInitialized()
    {
        _usuarios = Sistema.ObtenerUsuarios();
    }

    private void EliminarUsuario(Email correo)
    {
        Sistema.EliminarUsuario(correo.ToString());
        StateHasChanged();
    }
}