@page "/catalogos/{titulo}/editar"
@rendermode InteractiveServer
@using NearDupFinder_Dominio.Clases
@inject Sistema Sistema
@inject Microsoft.AspNetCore.Components.NavigationManager Nav

<PageTitle>Editar de Catalogo</PageTitle>

<h3>Editar Catalogo</h3>

@if(_error)
{
    <div class="alert alert-danger" role="alert">
        @_mensajeDeError
    </div>
}
@if (_catalogo is not null)
{
    <form>
        <div class="form-group">
            <label for="titulo">Titulo</label>
            <input type="text" class="form-control" id="titulo" @bind="_titulo"/>
        </div>

        <div class="form-group">
            <label for="Descripcion">Descripcion</label>
            <textarea type="text" class="form-control" id="descripcion" @bind="_descripcion" rows="5"></textarea>
        </div>

        <button type="button" class="btn btn-primary mt-3" @onclick="Guardar" >Guardar</button>
        <button type="button" class="btn btn-secondary mt-3" @onclick="Cancelar">Cancelar</button>
    </form>
}
else
{
    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Retornar</button>
}

@code {
    [Parameter]
    public string? titulo { get; set; }

    private Catalogo? _catalogo;
    private string _titulo = string.Empty;
    private string _descripcion = string.Empty;
    private bool _error;
    private string _mensajeDeError;

    protected override void OnParametersSet()
    {
        var buscado = Uri.UnescapeDataString(titulo ?? string.Empty);
        
        _catalogo = Sistema.ObtenerCatalogoPorTitulo(buscado);

        if (_catalogo is null)
        {
            NotificarError("El catalogo que deseas editar no existe.");
            return;
        }

        _error = false;
        _titulo = _catalogo.Titulo;
        _descripcion = _catalogo.Descripcion;
    }

    private void Guardar()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_titulo))
            {
                NotificarError("El Titulo no puede ser vacio, intente nuevamente");
                return;
            }

            Sistema.CambiarTituloCatalogo(_catalogo, _titulo);
            Sistema.CambiarDescripcionCatalogo(_catalogo, _titulo);


            Nav.NavigateTo("/CrearCatalogo");
        }catch (InvalidOperationException ex)
        {
            NotificarError(ex.Message);
        }
        catch (ArgumentException ex)
        {
            NotificarError(ex.Message);
        }
    }

    private void Cancelar() => Nav.NavigateTo("/CrearCatalogo");
    
    private void NotificarError(string mensaje)
    {
        _error = true;
        _mensajeDeError = mensaje;
    }
}
