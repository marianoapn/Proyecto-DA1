@page "/duplicados"
@using System.Text.RegularExpressions
@using NearDupFinder_Dominio.Clases
@using NearDupFinder_Dominio.Controladores
@inject Sistema Sistema
@rendermode InteractiveServer

<PageTitle>Duplicados</PageTitle>

<h3>Detección de Duplicados</h3>

@if (_duplicados.Count == 0)
{
    <div>No se encontraron duplicados.</div>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
        <tr>
            <th>Item</th>
            <th>Posible duplicado</th>
            <th>Jaccard Título</th>
            <th>Jaccard Descripción</th>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Score Total</th>
            <th>Estado</th> 
            <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var d in _duplicados)
        {
            <tr>
                <td>@d.ItemA.Titulo</td>
                <td>@d.ItemB.Titulo</td>
                <td>@d.JaccardTitulo.ToString("0.00")</td>
                <td>@d.JaccardDescripcion.ToString("0.00")</td>
                <td>@d.ScoreMarca</td>
                <td>@d.ScoreModelo</td>
                <td>@d.Score.ToString("0.00")</td>
                <td>
                    @if (d.Tipo == TipoDuplicado.AlertaDuplicado)
                    {
                        <span class="badge bg-secondary">POSIBLE DUPLICADO</span>  
                    }
                    else if (d.Tipo == TipoDuplicado.PosibleDuplicado)
                    {
                        <span class="badge bg-warning">DUPLICADO SUGERIDO</span>   
                    }

                        </td>
                <td>
                    <button class="btn btn-success btn-sm me-1" @onclick="() => ConfirmarDuplicado(d)" title="Confirmar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" class="bi bi-check2" viewBox="0 0 16 16">
                            <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0"/>
                        </svg>
                    </button>

                    <button class="btn btn-info btn-sm" @onclick="() => AbrirModalComparar(d)" title="Comparar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" class="bi bi-arrow-left-right ms-1" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1 11.5a.5.5 0 0 0 .5.5h11.793l-3.147 3.146a.5.5 0 0 0 .708.708l4-4a.5.5 0 0 0 0-.708l-4-4a.5.5 0 0 0-.708.708L13.293 11H1.5a.5.5 0 0 0-.5.5m14-7a.5.5 0 0 1-.5.5H2.707l3.147 3.146a.5.5 0 1 1-.708.708l-4-4a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 4H14.5a.5.5 0 0 1 .5.5"/>
                        </svg>
                    </button>

                    <button class="btn btn-danger btn-sm me-1" @onclick="() => DesacrtarDuplicado(d)" title="Descartar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" class="bi bi-x-lg" viewBox="0 0 16 16">
                            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
                        </svg>
                    </button>


                   
          
                    </td>
            </tr>
        }
        </tbody>

    </table>
}

<!-- Modal Comparar: lado a lado con tokens resaltados -->
@if (_mostrarModalComparar && _duplicadoSeleccionado.HasValue)
{
    var d = _duplicadoSeleccionado.Value;
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Comparar Items</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalComparar"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-6 border-end">
                            <h6>Item A</h6>
                            <p><b>Título:</b> @ResaltarTokens(d.ItemA.Titulo, d.TokensCompartidosTitulo)</p>
                            <p><b>Descripción:</b> @ResaltarTokens(d.ItemA.Descripcion, d.TokensCompartidosDescripcion)</p>
                            <p><b>Marca:</b> @d.ItemA.Marca</p>
                            <p><b>Modelo:</b> @d.ItemA.Modelo</p>
                        </div>
                        <div class="col-6">
                            <h6>Item B</h6>
                            <p><b>Título:</b> @ResaltarTokens(d.ItemB.Titulo, d.TokensCompartidosTitulo)</p>
                            <p><b>Descripción:</b> @ResaltarTokens(d.ItemB.Descripcion, d.TokensCompartidosDescripcion)</p>
                            <p><b>Marca:</b> @d.ItemB.Marca</p>
                            <p><b>Modelo:</b> @d.ItemB.Modelo</p>
                        </div>
                    </div>
                    <p><b>Score Total:</b> @d.Score.ToString("0.00")</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModalComparar">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ParDuplicado> _duplicados = new();
    private bool _mostrarModalComparar;
    private ParDuplicado? _duplicadoSeleccionado;

    protected override void OnInitialized()
    {
        CargarDuplicados();
    }

    private void CargarDuplicados()
    {
        _duplicados = Sistema.DuplicadosGlobales
            .OrderByDescending(d => d.Score)
            .ToList();
    }
    private void ConfirmarDuplicado(ParDuplicado d) => _duplicados.Remove(d);

    private void DesacrtarDuplicado(ParDuplicado d)
    {
        Sistema.DescartarParDuplicado(d);
        _duplicados.Remove(d);
    }

    private void AbrirModalComparar(ParDuplicado d)
    {
        _duplicadoSeleccionado = d;
        _mostrarModalComparar = true;
    }

    private void CerrarModalComparar()
    {
        _duplicadoSeleccionado = null;
        _mostrarModalComparar = false;
    }
    
    private MarkupString ResaltarTokens(string textoOriginal, string[]? tokensCompartidos)
    {
        if (string.IsNullOrEmpty(textoOriginal) || tokensCompartidos == null || tokensCompartidos.Length == 0)
            return (MarkupString)textoOriginal;

        string resultado = textoOriginal;

        foreach (var token in tokensCompartidos.Distinct())
        {
            if (string.IsNullOrWhiteSpace(token)) continue;

            resultado = Regex.Replace(
                resultado,
                $@"\b{Regex.Escape(token)}\b",
                $"<span class='bg-warning'>{token}</span>",
                RegexOptions.IgnoreCase
            );
        }

        return (MarkupString)resultado;
    }
}