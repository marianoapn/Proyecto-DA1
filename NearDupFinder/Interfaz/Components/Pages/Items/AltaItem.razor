@page "/alta-item"
@rendermode InteractiveServer
@using NearDupFinder_Dominio.Clases
@using NearDupFinder_Dominio.Excepciones
@inject Sistema sistema
@inject NavigationManager Nav

<PageTitle>Crear Item</PageTitle>

<h3>Crear Item</h3>

@if (!string.IsNullOrEmpty(_mensajeError))
{
    <div class="alert alert-danger">@_mensajeError</div>
}

<!-- Select de catálogo -->
<div class="mb-3">
    <label for="catalogoSelect">Seleccionar Catálogo:</label>
    <select id="catalogoSelect" class="form-select" @bind="_catalogoSeleccionadoTitulo">
        <option value="">-- Seleccione un catálogo --</option>
        @foreach (var cat in sistema.Catalogos)
        {
            <option value="@cat.Titulo">@cat.Titulo</option>
        }
    </select>
</div>
<!-- Fin de select de catálogo -->


<div class="mb-3">
    <label>Título:</label>
    <input class="form-control" @bind="_titulo" />
</div>

<div class="mb-3">
    <label>Descripción:</label>
    <input class="form-control" @bind="_descripcion" />
</div>

<div class="mb-3">
    <label>Categoría:</label>
    <input class="form-control" @bind="_categoria" />
</div>

<div class="mb-3">
    <label>Marca:</label>
    <input class="form-control" @bind="_marca" />
</div>

<div class="mb-3">
    <label>Modelo:</label>
    <input class="form-control" @bind="_modelo" />
</div>

<button class="btn btn-primary" @onclick="GuardarItem">Guardar</button>
<button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

@code {
    private string _titulo = "";
    private string _descripcion = "";
    private string _categoria = "";
    private string _marca = "";
    private string _modelo = "";
    private string _catalogoSeleccionadoTitulo = "";
    private string _mensajeError = "";

    private void GuardarItem()
    {
        try
        {
            var nuevoItem = new Item
            {
                Titulo = _titulo,
                Descripcion = _descripcion,
                Categoria = string.IsNullOrWhiteSpace(_categoria) ? "" : _categoria,
                Marca = string.IsNullOrWhiteSpace(_marca) ? "" : _marca,
                Modelo = string.IsNullOrWhiteSpace(_modelo) ? "" : _modelo
            };

            sistema.AltaItemConAltaDuplicados(_catalogoSeleccionadoTitulo, nuevoItem);

            Nav.NavigateTo("/lista-items");
        }
        catch (ItemException ex)
        {
            _mensajeError = ex.Message;
        }
    }


    private void Cancelar()
    {
        Nav.NavigateTo("/lista-CRUD");
    }

}
