@page "/logs"
@using NearDupFinder_Dominio.Clases
@using NearDupFinder_LogicaDeNegocio
@inject Sistema Sistema
@rendermode InteractiveServer

<PageTitle>Logs del Sistema</PageTitle>

<h3>Historial de Logs</h3>

@if (!_logs.Any())
{
    <div>No hay logs que mostrar.</div>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
        <tr>
            <th>Fecha / Hora</th>
            <th>Usuario</th>
            <th>Acción</th>
            <th>Detalles</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var log in _logs)
        {
            <tr>
                <td>@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@log.Usuario</td>
                <td>@log.Accion</td>
                <td>@log.Detalles</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<EntradaDeLog> _logs = new();

    protected override void OnInitialized()
    {
        _logs = Sistema.ObtenerLogs()
            .OrderByDescending(l => l.Timestamp)
            .ToList();
    }
}