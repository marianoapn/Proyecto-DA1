@page "/alta-item"
@rendermode InteractiveServer
@using NearDupFinder_LogicaDeNegocio.DTOs.ParaGestorItems
@using NearDupFInder_LogicaDeNegocio.Servicios.Catalogos
@using NearDupFinder_LogicaDeNegocio.Servicios.Items
@inject GestorCatalogos GestorCatalogos;
@inject ControladorItems ControladorItems
@inject NavigationManager Nav

<PageTitle>Crear Item</PageTitle>

<h3>Crear Item</h3>

@if (!string.IsNullOrEmpty(_mensajeError))
{
    <div class="alert alert-danger">@_mensajeError</div>
}

<div class="mb-3">
    <label for="catalogoSelect">Seleccionar Catálogo:</label>
    <select id="catalogoSelect" class="form-select" @bind="_catalogoSeleccionadoId">
        <option value="">-- Seleccione un catálogo --</option>
        @foreach (var cat in GestorCatalogos.ObtenerCatalogos())
        {
            <option value="@cat.Id">@cat.Titulo</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Título:</label>
    <input class="form-control" @bind="_titulo" />
</div>

<div class="mb-3">
    <label>Descripción:</label>
    <input class="form-control" @bind="_descripcion" />
</div>

<div class="mb-3">
    <label>Categoría:</label>
    <input class="form-control" @bind="_categoria" />
</div>

<div class="mb-3">
    <label>Marca:</label>
    <input class="form-control" @bind="_marca" />
</div>

<div class="mb-3">
    <label>Modelo:</label>
    <input class="form-control" @bind="_modelo" />
</div>

<div class="mb-3">
    <label>Stock:</label>
    <input class="form-control" type="number" @bind="_stock" />
</div>

<div class="mb-3">
    <label>Precio:</label>
    <input class="form-control" type="number" @bind="_precio" />
</div>

<div class="mb-3">
    <label>Imagen:</label>
    <InputFile OnChange="OnInputFileChange" />
</div>

@if (!string.IsNullOrEmpty(_imagenBase64))
{
    <div class="mb-3">
        <label>Vista previa:</label><br />
        <img src="data:image/png;base64,@_imagenBase64"
             style="max-width: 200px; max-height: 200px;" />
    </div>
}

<button class="btn btn-primary" @onclick="GuardarItem">Guardar</button>
<button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

@code {
    private string _titulo = "";
    private string _descripcion = "";
    private string _categoria = "";
    private string _marca = "";
    private string _modelo = "";
    private int? _catalogoSeleccionadoId;
    private string _mensajeError = "";
    private int _stock;
    private int? _precio;
    private string? _imagenBase64;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        _mensajeError = "";

        var file = e.File;
        if (file is null)
        {
            _imagenBase64 = null;
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            _imagenBase64 = Convert.ToBase64String(bytes);
        }
        catch (Exception)
        {
            _mensajeError = "Error al cargar la imagen. Verifique el tamaño y el formato.";
            _imagenBase64 = null;
        }
    }

    private void GuardarItem()
    {
        try
        {
            var datos = new DatosCrearItem(
                IdCatalogo: _catalogoSeleccionadoId ?? 0,
                Titulo: _titulo,
                Descripcion: _descripcion,
                Categoria: string.IsNullOrWhiteSpace(_categoria) ? null : _categoria,
                Marca: string.IsNullOrWhiteSpace(_marca) ? null : _marca,
                Modelo: string.IsNullOrWhiteSpace(_modelo) ? null : _modelo,
                Stock: _stock,
                Precio: _precio,
                ImagenBase64: _imagenBase64
            );

            ControladorItems.CrearItem(datos);

            Nav.NavigateTo("/lista-items");
        }
        catch (Exception ex)
        {
            _mensajeError = ex.Message;
        }
        
    }
    
    private void Cancelar()
    {
        Nav.NavigateTo("/lista-items");
    }
}
