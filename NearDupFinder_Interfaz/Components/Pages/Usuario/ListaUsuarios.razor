@page "/usuarios"

@rendermode InteractiveServer
@using NearDupFinder_Dominio.Clases
@using NearDupFinder_LogicaDeNegocio.DTOs.ParaGestorUsuario
@using NearDupFinder_LogicaDeNegocio.Servicios
@attribute [Authorize(Roles = "Administrador")]
@inject GestorUsuarios GestorUsuarios

<PageTitle>Usuarios</PageTitle>

<div class="d-flex align-items-center mb-3">
    <h1 class="h1 mb-0">Usuarios</h1>
    <a href="/crear-usuario" class="btn btn-success btn-sm ms-auto">
        <i class="bi bi-person-plus me-1"></i>
        Crear usuario
    </a>
</div>

@if(_error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @_mensajeDeError
        <button type="button" class="btn-close" @onclick="CerrarAlerta" aria-label="Cerrar"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
        <tr>
            <th scope="col">Nombre</th>
            <th scope="col">Apellido</th>
            <th scope="col">Email</th>
            <th scope="col">Fecha de nacimiento</th>
            <th scope="col">Roles</th>
            <th scope="col" class="text-end">Acciones</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var usuario in _usuarios!)
        {
            var roles = GestorUsuarios.ObtenerRolesDeUsuario(usuario);
            <tr>
                <td>@usuario.Nombre</td>
                <td>@usuario.Apellido</td>
                <td>@usuario.Email.ToString()</td>
                <td>@usuario.FechaNacimiento.ToString()</td>
                <td>
                    @if (roles.Any())
                    {
                        @string.Join(", ", roles.Select(r => r.ToString()))
                    }
                    else
                    {
                        <em class="text-muted">Sin roles</em>
                    }
                </td>
                <td class="text-end text-nowrap">
                    <div class="d-inline-flex gap-2">
                        <a class="btn btn-primary btn-sm d-inline-flex align-items-center justify-content-center"
                           href="usuarios/@usuario.Id/editar"
                           aria-label="Editar" title="Editar">
                            <i class="bi bi-pencil-square fs-6 lh-1"></i>
                        </a>

                        <button class="btn btn-danger btn-sm d-inline-flex align-items-center justify-content-center"
                                @onclick="(() => EliminarUsuario(usuario.Email))"
                                aria-label="Eliminar" title="Eliminar">
                            <i class="bi bi-trash3 fs-6 lh-1"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@code {
    private IReadOnlyList<Usuario>? _usuarios;
    private bool _error;
    private string _mensajeDeError = string.Empty;


    protected override void OnInitialized()
    {
        _usuarios = GestorUsuarios.ObtenerUsuarios();
    }

    private void EliminarUsuario(Email correo)
    {
        bool seEliminoElUsuario = GestorUsuarios.BorrarUsuario(new DatosUsuarioEmail(correo.ToString()));
        if(!seEliminoElUsuario)
            NotificarError("Error al intentar eliminar el usuario.");
        _usuarios = GestorUsuarios.ObtenerUsuarios();
        StateHasChanged();
    }
    
    private void NotificarError(string mensaje)
    {
        _error = true;
        _mensajeDeError = mensaje;
    }
    
    private void CerrarAlerta()
    {
        _error = false;
        _mensajeDeError = string.Empty;
    }
}